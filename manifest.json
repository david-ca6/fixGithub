{
  "manifest_version": 3,
  "name": "FixGitHub",
  "description": "Fixes GitHub by adding kittens where they are clearly needed.",
  "version": "0.1.0",
  "content_scripts": [
    {
      "matches": ["https://github.com/*"],
      "js": ["content.js"],
      "css": ["styles.css"],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["assets/octocat.png"],
      "matches": ["https://github.com/*"]
    }
  ]
}
